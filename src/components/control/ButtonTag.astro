---
import Button from '@components/Button'

interface Props {
  size?: string
  dot?: boolean
  href?: string
  label?: string
}
const { dot, href, label }: Props = Astro.props
---

<Button
  as="a"
  variant="regular"
  href={href}
  aria-label={label}
  class="h-8 text-sm px-3 rounded-lg"
>
  {
    dot && (
      <div class="h-1 w-1 bg-[var(--btn-content)] dark:bg-[var(--card-bg)] transition rounded-md mr-2" />
    )
  }
  <slot />
</Button>
